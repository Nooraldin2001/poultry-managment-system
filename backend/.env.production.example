# ─────────────────────────────────────────────────────────────────────────
# Poultry Hero — PRODUCTION env example.
#
# Copy to backend/.env ON THE VPS and fill in real values. NEVER commit .env.
#
# SECURITY:
#   * NEVER use the same value for the database password and the Django secret key.
#   * Generate a long, random Django secret key (see VPS guide for the command).
#   * Keep this file (the *.example) free of real secrets — placeholders only.
# ─────────────────────────────────────────────────────────────────────────

# --- Core ---
DJANGO_SECRET_KEY=CHANGE_ME_GENERATED_DJANGO_SECRET_KEY
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.poultryhero.solutions,poultryhero.solutions,www.poultryhero.solutions,admin.poultryhero.solutions,demo.poultryhero.solutions,153.92.5.195

# --- Environment / data hygiene ---
# Production must NEVER auto-create demo business data. Demo seed commands are
# manual + opt-in (they require --confirm-demo-data). Keep ENABLE_DEMO_DATA=False
# on production tenants; only enable on local/staging if you script demo seeding.
ENVIRONMENT=production
ENABLE_DEMO_DATA=False

# Gunicorn loads config.settings.production by default (config/wsgi.py), and the
# systemd unit also exports it. Uncomment only if you need to override:
# DJANGO_SETTINGS_MODULE=config.settings.production

# --- CSRF / CORS (note: variable names match the Django settings) ---
CSRF_TRUSTED_ORIGINS=https://poultryhero.solutions,https://www.poultryhero.solutions,https://admin.poultryhero.solutions,https://demo.poultryhero.solutions
CORS_ALLOWED_ORIGINS=https://poultryhero.solutions,https://www.poultryhero.solutions,https://admin.poultryhero.solutions,https://demo.poultryhero.solutions
# Regex covers all tenant workspace subdomains (https://{sub}.poultryhero.solutions)
CORS_ALLOWED_ORIGIN_REGEXES=^https://([a-z0-9-]+)\.poultryhero\.solutions$

# --- Database (PostgreSQL) ---
# Use a STRONG password that is DIFFERENT from DJANGO_SECRET_KEY.
DATABASE_URL=postgres://poultryhero_user:CHANGE_ME_STRONG_DATABASE_PASSWORD@localhost:5432/poultryhero

# --- Localization ---
DEFAULT_TIME_ZONE=Asia/Dubai

# --- Media ---
MEDIA_ROOT=/var/www/poultryhero/backend/media
MEDIA_URL=/media/

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Tenancy / business defaults ---
BASE_DOMAIN=poultryhero.solutions
SUPERADMIN_SUBDOMAIN=admin
DEFAULT_VAT_RATE=5.00
DEFAULT_PLAN_USER_LIMIT=3

# ─────────────────────────────────────────────────────────────────────────
# Informational (handled in code, not read from this file):
#   STATIC_ROOT is fixed to backend/staticfiles in settings/base.py.
#   SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https is set in
#   settings/production.py (so Django trusts Nginx's X-Forwarded-Proto).
# ─────────────────────────────────────────────────────────────────────────
