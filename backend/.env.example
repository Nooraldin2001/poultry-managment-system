# Poultry Hero backend environment example. Copy to backend/.env for local dev.

# --- Core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.poultryhero.solutions

# --- Database ---
# Production (PostgreSQL):
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/poultryhero
# Or individual parts (if you prefer, wire them into DATABASE_URL yourself):
# DB_NAME=poultryhero
# DB_USER=poultry
# DB_PASSWORD=secret
# DB_HOST=127.0.0.1
# DB_PORT=5432
# Leave DATABASE_URL unset to use local SQLite (db.sqlite3).

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Localization ---
DEFAULT_TIME_ZONE=Asia/Dubai

# --- Media ---
MEDIA_ROOT=media
MEDIA_URL=/media/

# --- Tenancy ---
BASE_DOMAIN=poultryhero.solutions
SUPERADMIN_SUBDOMAIN=admin

# --- Business defaults ---
DEFAULT_VAT_RATE=5.00
DEFAULT_PLAN_USER_LIMIT=3

# --- Production only ---
# CSRF_TRUSTED_ORIGINS=https://*.poultryhero.solutions
