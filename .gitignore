# ─────────────────────────────────────────────────────────────────────────
# Poultry Hero — root .gitignore
# NOTE: Django migration files are intentionally NOT ignored and MUST stay
# committed. Production deploys run `migrate` (never `makemigrations`).
# ─────────────────────────────────────────────────────────────────────────

# --- Python ---
__pycache__/
*.py[cod]
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# --- Django ---
backend/.env
backend/staticfiles/
backend/media/
*.sqlite3
db.sqlite3

# --- Frontend ---
node_modules/
**/node_modules/
dist/
build/
.vite/
.turbo/
.next/

# --- Deployment / local ---
logs/
*.log

# --- Env files (never commit real secrets) ---
.env
.env.*
!.env.example
!.env.production.example

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
